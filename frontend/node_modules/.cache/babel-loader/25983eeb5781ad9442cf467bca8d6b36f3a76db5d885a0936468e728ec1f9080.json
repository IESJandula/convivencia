{"ast":null,"code":"import axios from 'axios';\nconst API_URL = 'http://localhost:8080/api';\nexport default {\n  name: 'NuevoParte',\n  data() {\n    return {\n      parte: {\n        profesorEmail: '',\n        fecha: new Date().toISOString().split('T')[0],\n        curso: '',\n        alumnoId: '',\n        descripcion: '',\n        medidaTomada: 'AULA_CONVIVENCIA',\n        tareas: '',\n        archivoUrl: '',\n        conductaId: ''\n      },\n      alumnos: [],\n      conductas: [],\n      mensaje: '',\n      mensajeTipo: ''\n    };\n  },\n  mounted() {\n    this.cargarConductas();\n  },\n  methods: {\n    async cargarConductas() {\n      try {\n        const response = await axios.get(`${API_URL}/conductas`);\n        this.conductas = response.data;\n      } catch (error) {\n        console.error('Error al cargar conductas:', error);\n      }\n    },\n    async cargarAlumnos() {\n      if (!this.parte.curso) return;\n      try {\n        const response = await axios.get(`${API_URL}/alumnos/curso/${this.parte.curso}`);\n        this.alumnos = response.data;\n      } catch (error) {\n        console.error('Error al cargar alumnos:', error);\n      }\n    },\n    async crearParte() {\n      try {\n        await axios.post(`${API_URL}/partes`, this.parte);\n        this.mensaje = '✅ Parte creado exitosamente';\n        this.mensajeTipo = 'success';\n        this.limpiarFormulario();\n        setTimeout(() => this.mensaje = '', 3000);\n      } catch (error) {\n        this.mensaje = '❌ Error al crear el parte: ' + (error.response?.data?.message || error.message);\n        this.mensajeTipo = 'error';\n      }\n    },\n    limpiarFormulario() {\n      this.parte = {\n        profesorEmail: '',\n        fecha: new Date().toISOString().split('T')[0],\n        curso: '',\n        alumnoId: '',\n        descripcion: '',\n        medidaTomada: 'AULA_CONVIVENCIA',\n        tareas: '',\n        archivoUrl: '',\n        conductaId: ''\n      };\n      this.alumnos = [];\n    }\n  }\n};","map":{"version":3,"names":["axios","API_URL","name","data","parte","profesorEmail","fecha","Date","toISOString","split","curso","alumnoId","descripcion","medidaTomada","tareas","archivoUrl","conductaId","alumnos","conductas","mensaje","mensajeTipo","mounted","cargarConductas","methods","response","get","error","console","cargarAlumnos","crearParte","post","limpiarFormulario","setTimeout","message"],"sources":["C:\\Users\\Adrian\\Desktop\\partes-convivencia-completo\\frontend\\src\\components\\NuevoParte.vue"],"sourcesContent":["<template>\r\n    <div class=\"card\">\r\n      <h2>📝 Nuevo Parte Disciplinario</h2>\r\n      \r\n      <div v-if=\"mensaje\" :class=\"['alert', mensajeTipo === 'success' ? 'alert-success' : 'alert-error']\">\r\n        {{ mensaje }}\r\n      </div>\r\n  \r\n      <form @submit.prevent=\"crearParte\">\r\n        <div class=\"form-group\">\r\n          <label>Profesor (Email) *</label>\r\n          <input \r\n            type=\"email\" \r\n            v-model=\"parte.profesorEmail\" \r\n            required\r\n            placeholder=\"profesor@instituto.es\"\r\n          />\r\n        </div>\r\n  \r\n        <div class=\"form-group\">\r\n          <label>Fecha *</label>\r\n          <input \r\n            type=\"date\" \r\n            v-model=\"parte.fecha\" \r\n            required\r\n          />\r\n        </div>\r\n  \r\n        <div class=\"form-group\">\r\n          <label>Curso *</label>\r\n          <select v-model=\"parte.curso\" @change=\"cargarAlumnos\" required>\r\n            <option value=\"\">Seleccione un curso</option>\r\n            <option value=\"1º ESO\">1º ESO</option>\r\n            <option value=\"2º ESO\">2º ESO</option>\r\n            <option value=\"3º ESO\">3º ESO</option>\r\n            <option value=\"4º ESO\">4º ESO</option>\r\n            <option value=\"1º BIC\">1º BIC</option>\r\n            <option value=\"OS1B\">OS1B</option>\r\n          </select>\r\n        </div>\r\n  \r\n        <div class=\"form-group\">\r\n          <label>Alumno *</label>\r\n          <select v-model=\"parte.alumnoId\" required :disabled=\"!alumnos.length\">\r\n            <option value=\"\">Seleccione un alumno</option>\r\n            <option v-for=\"alumno in alumnos\" :key=\"alumno.id\" :value=\"alumno.id\">\r\n              {{ alumno.nombre }} {{ alumno.apellidos }} ({{ alumno.grupo }})\r\n            </option>\r\n          </select>\r\n        </div>\r\n  \r\n        <div class=\"form-group\">\r\n          <label>Conducta Contraria *</label>\r\n          <select v-model=\"parte.conductaId\" required>\r\n            <option value=\"\">Seleccione una conducta</option>\r\n            <option v-for=\"conducta in conductas\" :key=\"conducta.id\" :value=\"conducta.id\">\r\n              {{ conducta.codigo }}. {{ conducta.descripcion }}\r\n            </option>\r\n          </select>\r\n        </div>\r\n  \r\n        <div class=\"form-group\">\r\n          <label>Descripción *</label>\r\n          <textarea \r\n            v-model=\"parte.descripcion\" \r\n            required\r\n            placeholder=\"Describa la conducta del alumno...\"\r\n          ></textarea>\r\n        </div>\r\n  \r\n        <div class=\"form-group\">\r\n          <label>Medida Tomada *</label>\r\n          <div class=\"radio-group\">\r\n            <label>\r\n              <input \r\n                type=\"radio\" \r\n                v-model=\"parte.medidaTomada\" \r\n                value=\"AULA_CONVIVENCIA\"\r\n              /> Aula de Convivencia\r\n            </label>\r\n            <label>\r\n              <input \r\n                type=\"radio\" \r\n                v-model=\"parte.medidaTomada\" \r\n                value=\"SE_QUEDA_EN_CLASE\"\r\n              /> Se queda en clase\r\n            </label>\r\n          </div>\r\n        </div>\r\n  \r\n        <div v-if=\"parte.medidaTomada === 'AULA_CONVIVENCIA'\" class=\"aula-fields\">\r\n          <div class=\"form-group\">\r\n            <label>Tareas para realizar</label>\r\n            <textarea \r\n              v-model=\"parte.tareas\" \r\n              placeholder=\"Ejemplo: Realizar la ficha nº 17, Copiar el tema 3...\"\r\n            ></textarea>\r\n          </div>\r\n  \r\n          <div class=\"form-group\">\r\n            <label>Adjuntar documento/foto (URL)</label>\r\n            <input \r\n              type=\"url\" \r\n              v-model=\"parte.archivoUrl\" \r\n              placeholder=\"https://...\"\r\n            />\r\n          </div>\r\n        </div>\r\n  \r\n        <div class=\"form-actions\">\r\n          <button type=\"button\" class=\"btn btn-secondary\" @click=\"limpiarFormulario\">\r\n            Cancelar\r\n          </button>\r\n          <button type=\"submit\" class=\"btn btn-primary\">\r\n            💾 Guardar Parte\r\n          </button>\r\n        </div>\r\n      </form>\r\n    </div>\r\n  </template>\r\n  \r\n  <script>\r\n  import axios from 'axios'\r\n  \r\n  const API_URL = 'http://localhost:8080/api'\r\n  \r\n  export default {\r\n    name: 'NuevoParte',\r\n    data() {\r\n      return {\r\n        parte: {\r\n          profesorEmail: '',\r\n          fecha: new Date().toISOString().split('T')[0],\r\n          curso: '',\r\n          alumnoId: '',\r\n          descripcion: '',\r\n          medidaTomada: 'AULA_CONVIVENCIA',\r\n          tareas: '',\r\n          archivoUrl: '',\r\n          conductaId: ''\r\n        },\r\n        alumnos: [],\r\n        conductas: [],\r\n        mensaje: '',\r\n        mensajeTipo: ''\r\n      }\r\n    },\r\n    mounted() {\r\n      this.cargarConductas()\r\n    },\r\n    methods: {\r\n      async cargarConductas() {\r\n        try {\r\n          const response = await axios.get(`${API_URL}/conductas`)\r\n          this.conductas = response.data\r\n        } catch (error) {\r\n          console.error('Error al cargar conductas:', error)\r\n        }\r\n      },\r\n      async cargarAlumnos() {\r\n        if (!this.parte.curso) return\r\n        try {\r\n          const response = await axios.get(`${API_URL}/alumnos/curso/${this.parte.curso}`)\r\n          this.alumnos = response.data\r\n        } catch (error) {\r\n          console.error('Error al cargar alumnos:', error)\r\n        }\r\n      },\r\n      async crearParte() {\r\n        try {\r\n          await axios.post(`${API_URL}/partes`, this.parte)\r\n          this.mensaje = '✅ Parte creado exitosamente'\r\n          this.mensajeTipo = 'success'\r\n          this.limpiarFormulario()\r\n          setTimeout(() => this.mensaje = '', 3000)\r\n        } catch (error) {\r\n          this.mensaje = '❌ Error al crear el parte: ' + (error.response?.data?.message || error.message)\r\n          this.mensajeTipo = 'error'\r\n        }\r\n      },\r\n      limpiarFormulario() {\r\n        this.parte = {\r\n          profesorEmail: '',\r\n          fecha: new Date().toISOString().split('T')[0],\r\n          curso: '',\r\n          alumnoId: '',\r\n          descripcion: '',\r\n          medidaTomada: 'AULA_CONVIVENCIA',\r\n          tareas: '',\r\n          archivoUrl: '',\r\n          conductaId: ''\r\n        }\r\n        this.alumnos = []\r\n      }\r\n    }\r\n  }\r\n  </script>\r\n  \r\n  <style scoped>\r\n  .radio-group {\r\n    display: flex;\r\n    gap: 2rem;\r\n  }\r\n  \r\n  .radio-group label {\r\n    display: flex;\r\n    align-items: center;\r\n    gap: 0.5rem;\r\n    cursor: pointer;\r\n  }\r\n  \r\n  .aula-fields {\r\n    background: #f8f9fa;\r\n    padding: 1.5rem;\r\n    border-radius: 8px;\r\n    margin-top: 1rem;\r\n  }\r\n  \r\n  .form-actions {\r\n    display: flex;\r\n    gap: 1rem;\r\n    justify-content: flex-end;\r\n    margin-top: 2rem;\r\n  }\r\n  </style>"],"mappings":"AA0HE,OAAOA,KAAI,MAAO,OAAM;AAExB,MAAMC,OAAM,GAAI,2BAA0B;AAE1C,eAAe;EACbC,IAAI,EAAE,YAAY;EAClBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,KAAK,EAAE;QACLC,aAAa,EAAE,EAAE;QACjBC,KAAK,EAAE,IAAIC,IAAI,CAAC,CAAC,CAACC,WAAW,CAAC,CAAC,CAACC,KAAK,CAAC,GAAG,CAAC,CAAC,CAAC,C