{"ast":null,"code":"import axios from 'axios';\nconst API_URL = 'http://localhost:8080/api';\nexport default {\n  name: 'AulaConvivencia',\n  data() {\n    return {\n      partesAula: [],\n      fecha: new Date().toISOString().split('T')[0],\n      tramoActual: this.obtenerTramoActual(),\n      profesorGuardia: 'antonio.oliver@instituto.es',\n      modalTareas: null,\n      mensaje: '',\n      mensajeTipo: '',\n      cargando: false,\n      guardando: false\n    };\n  },\n  mounted() {\n    this.cargarPartes();\n  },\n  methods: {\n    obtenerTramoActual() {\n      const hora = new Date().getHours();\n      if (hora >= 8 && hora < 9) return '1';\n      if (hora >= 9 && hora < 10) return '2';\n      if (hora >= 10 && hora < 11) return '3';\n      if (hora >= 11 && hora < 12) return '4';\n      if (hora >= 12 && hora < 13) return '5';\n      if (hora >= 13 && hora < 14) return '6';\n      return '3'; // Por defecto 3ª hora\n    },\n    async cargarPartes() {\n      this.cargando = true;\n      this.mensaje = '';\n      try {\n        const response = await axios.get(`${API_URL}/partes/aula-convivencia`, {\n          params: {\n            fecha: this.fecha\n          }\n        });\n        this.partesAula = response.data.map(parte => ({\n          ...parte,\n          trabaja: null,\n          comportamiento: ''\n        }));\n        if (this.partesAula.length > 0) {\n          this.mensaje = `✅ Se encontraron ${this.partesAula.length} alumno(s) en el aula de convivencia`;\n          this.mensajeTipo = 'success';\n        }\n      } catch (error) {\n        console.error('Error al cargar partes:', error);\n        this.mensaje = '❌ Error al cargar los partes del aula de convivencia';\n        this.mensajeTipo = 'error';\n      } finally {\n        this.cargando = false;\n      }\n    },\n    verTareas(parte) {\n      this.modalTareas = parte;\n    },\n    cerrarModal() {\n      this.modalTareas = null;\n    },\n    abrirDocumento(url) {\n      window.open(url, '_blank');\n    },\n    async guardarSesiones() {\n      // Validar que al menos un alumno tenga evaluación\n      const partesConEvaluacion = this.partesAula.filter(parte => parte.comportamiento || parte.trabaja !== null);\n      if (partesConEvaluacion.length === 0) {\n        this.mensaje = '⚠️ Por favor, evalúe al menos a un alumno antes de guardar';\n        this.mensajeTipo = 'error';\n        return;\n      }\n      if (!this.profesorGuardia) {\n        this.mensaje = '⚠️ Por favor, ingrese el email del profesor de guardia';\n        this.mensajeTipo = 'error';\n        return;\n      }\n      this.guardando = true;\n      let guardados = 0;\n      let errores = 0;\n      try {\n        for (const parte of partesConEvaluacion) {\n          try {\n            await axios.post(`${API_URL}/sesiones`, {\n              parteId: parte.id,\n              profesorGuardiaEmail: this.profesorGuardia,\n              fecha: this.fecha,\n              tramoHorario: this.tramoActual,\n              comportamiento: parte.comportamiento || null,\n              trabaja: parte.trabaja,\n              observaciones: ''\n            });\n            guardados++;\n          } catch (error) {\n            console.error('Error al guardar sesión:', error);\n            errores++;\n          }\n        }\n        if (errores === 0) {\n          this.mensaje = `✅ Se guardaron ${guardados} evaluación(es) exitosamente`;\n          this.mensajeTipo = 'success';\n          setTimeout(() => {\n            this.mensaje = '';\n            this.cargarPartes();\n          }, 3000);\n        } else {\n          this.mensaje = `⚠️ Se guardaron ${guardados} evaluación(es), pero ${errores} tuvieron errores`;\n          this.mensajeTipo = 'error';\n        }\n      } catch (error) {\n        console.error('Error general:', error);\n        this.mensaje = '❌ Error al guardar las evaluaciones';\n        this.mensajeTipo = 'error';\n      } finally {\n        this.guardando = false;\n      }\n    },\n    formatearFecha(fecha) {\n      if (!fecha) return '';\n      return new Date(fecha + 'T00:00:00').toLocaleDateString('es-ES', {\n        weekday: 'long',\n        day: '2-digit',\n        month: '2-digit',\n        year: 'numeric'\n      });\n    }\n  }\n};","map":{"version":3,"names":["axios","API_URL","name","data","partesAula","fecha","Date","toISOString","split","tramoActual","obtenerTramoActual","profesorGuardia","modalTareas","mensaje","mensajeTipo","cargando","guardando","mounted","cargarPartes","methods","hora","getHours","response","get","params","map","parte","trabaja","comportamiento","length","error","console","verTareas","cerrarModal","abrirDocumento","url","window","open","guardarSesiones","partesConEvaluacion","filter","guardados","errores","post","parteId","id","profesorGuardiaEmail","tramoHorario","observaciones","setTimeout","formatearFecha","toLocaleDateString","weekday","day","month","year"],"sources":["C:\\Users\\Adrian\\Desktop\\partes-convivencia-completo\\frontend\\src\\components\\AulaConvivencia.vue"],"sourcesContent":["<template>\r\n    <div class=\"card\">\r\n      <div class=\"header-guardia\">\r\n        <div>\r\n          <h2>🏫 Aula de Convivencia - Profesor de Guardia</h2>\r\n          <p class=\"info-guardia\">\r\n            <strong>Profesor de guardia:</strong> {{ profesorGuardia }} | \r\n            <strong>Fecha:</strong> {{ formatearFecha(fecha) }} | \r\n            <strong>Hora:</strong> {{ tramoActual }}ª\r\n          </p>\r\n        </div>\r\n        <button @click=\"cargarPartes\" class=\"btn btn-primary\">\r\n          🔄 Actualizar\r\n        </button>\r\n      </div>\r\n  \r\n      <div class=\"filtros\">\r\n        <div class=\"form-group\">\r\n          <label>Fecha</label>\r\n          <input type=\"date\" v-model=\"fecha\" @change=\"cargarPartes\" />\r\n        </div>\r\n        <div class=\"form-group\">\r\n          <label>Tramo Horario</label>\r\n          <select v-model=\"tramoActual\" @change=\"cargarPartes\">\r\n            <option value=\"1\">1ª (8:15 - 9:15)</option>\r\n            <option value=\"2\">2ª (9:15 - 10:15)</option>\r\n            <option value=\"3\">3ª (10:15 - 11:15)</option>\r\n            <option value=\"4\">4ª (11:45 - 12:45)</option>\r\n            <option value=\"5\">5ª (12:45 - 13:45)</option>\r\n            <option value=\"6\">6ª (13:45 - 14:45)</option>\r\n          </select>\r\n        </div>\r\n        <div class=\"form-group\">\r\n          <label>Email Profesor Guardia</label>\r\n          <input \r\n            type=\"email\" \r\n            v-model=\"profesorGuardia\" \r\n            placeholder=\"profesor@instituto.es\" \r\n          />\r\n        </div>\r\n      </div>\r\n  \r\n      <div v-if=\"mensaje\" :class=\"['alert', mensajeTipo === 'success' ? 'alert-success' : 'alert-error']\">\r\n        {{ mensaje }}\r\n      </div>\r\n  \r\n      <div v-if=\"cargando\" class=\"loading\">\r\n        <p>⏳ Cargando alumnos del aula de convivencia...</p>\r\n      </div>\r\n  \r\n      <div v-else-if=\"partesAula.length === 0\" class=\"sin-alumnos\">\r\n        <div class=\"empty-state\">\r\n          <span class=\"empty-icon\">📭</span>\r\n          <h3>No hay alumnos en el aula de convivencia</h3>\r\n          <p>No hay partes pendientes para este día y tramo horario.</p>\r\n        </div>\r\n      </div>\r\n  \r\n      <div v-else class=\"tabla-container\">\r\n        <table>\r\n          <thead>\r\n            <tr>\r\n              <th>N</th>\r\n              <th>Alumno</th>\r\n              <th>Grupo</th>\r\n              <th>Doc.</th>\r\n              <th>Tareas</th>\r\n              <th>Trabaja</th>\r\n              <th>Comportamiento</th>\r\n            </tr>\r\n          </thead>\r\n          <tbody>\r\n            <tr v-for=\"(parte, index) in partesAula\" :key=\"parte.id\">\r\n              <td class=\"numero\">{{ index + 1 }}</td>\r\n              <td class=\"alumno-nombre\">\r\n                <strong>{{ parte.alumnoApellidos }}, {{ parte.alumnoNombre }}</strong>\r\n              </td>\r\n              <td>{{ parte.curso }} {{ parte.grupo }}</td>\r\n              <td class=\"centro\">\r\n                <button \r\n                  v-if=\"parte.archivoUrl\" \r\n                  @click=\"abrirDocumento(parte.archivoUrl)\"\r\n                  class=\"btn-icon\"\r\n                  title=\"Ver documento adjunto\"\r\n                >\r\n                  📎\r\n                </button>\r\n                <span v-else class=\"no-doc\">-</span>\r\n              </td>\r\n              <td>\r\n                <button \r\n                  @click=\"verTareas(parte)\" \r\n                  class=\"btn-small btn-info\"\r\n                >\r\n                  Ver tareas [+]\r\n                </button>\r\n              </td>\r\n              <td>\r\n                <select v-model=\"parte.trabaja\" class=\"select-small\">\r\n                  <option :value=\"null\">Seleccione</option>\r\n                  <option :value=\"true\">✅ Sí</option>\r\n                  <option :value=\"false\">❌ No</option>\r\n                </select>\r\n              </td>\r\n              <td>\r\n                <select v-model=\"parte.comportamiento\" class=\"select-small\">\r\n                  <option value=\"\">Seleccione</option>\r\n                  <option value=\"BIEN\">😊 Bien</option>\r\n                  <option value=\"REGULAR\">😐 Regular</option>\r\n                  <option value=\"MAL\">😠 Mal</option>\r\n                </select>\r\n              </td>\r\n            </tr>\r\n          </tbody>\r\n        </table>\r\n  \r\n        <div class=\"form-actions\">\r\n          <button @click=\"guardarSesiones\" class=\"btn btn-success\" :disabled=\"guardando\">\r\n            {{ guardando ? '⏳ Guardando...' : '💾 Guardar Evaluaciones' }}\r\n          </button>\r\n        </div>\r\n      </div>\r\n  \r\n      <!-- Modal para ver tareas -->\r\n      <div v-if=\"modalTareas\" class=\"modal\" @click=\"cerrarModal\">\r\n        <div class=\"modal-content\" @click.stop>\r\n          <div class=\"modal-header\">\r\n            <h3>📝 Tareas Asignadas</h3>\r\n            <button @click=\"cerrarModal\" class=\"btn-close\">✕</button>\r\n          </div>\r\n          \r\n          <div class=\"tareas-content\">\r\n            <div class=\"info-alumno\">\r\n              <p><strong>Alumno:</strong> {{ modalTareas.alumnoNombre }} {{ modalTareas.alumnoApellidos }}</p>\r\n              <p><strong>Grupo:</strong> {{ modalTareas.curso }} {{ modalTareas.grupo }}</p>\r\n            </div>\r\n            \r\n            <div class=\"seccion\">\r\n              <h4>📋 Descripción del Incidente:</h4>\r\n              <p class=\"descripcion\">{{ modalTareas.descripcion }}</p>\r\n            </div>\r\n            \r\n            <div class=\"seccion\">\r\n              <h4>✏️ Tareas Asignadas:</h4>\r\n              <p class=\"tareas\">{{ modalTareas.tareas || 'No se especificaron tareas concretas' }}</p>\r\n            </div>\r\n            \r\n            <div v-if=\"modalTareas.archivoUrl\" class=\"seccion\">\r\n              <h4>📎 Documento Adjunto:</h4>\r\n              <a :href=\"modalTareas.archivoUrl\" target=\"_blank\" class=\"link-documento\">\r\n                🔗 Abrir documento en nueva pestaña\r\n              </a>\r\n            </div>\r\n          </div>\r\n          \r\n          <div class=\"modal-footer\">\r\n            <button @click=\"cerrarModal\" class=\"btn btn-secondary\">Cerrar</button>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </template>\r\n  \r\n  <script>\r\n  import axios from 'axios'\r\n  \r\n  const API_URL = 'http://localhost:8080/api'\r\n  \r\n  export default {\r\n    name: 'AulaConvivencia',\r\n    data() {\r\n      return {\r\n        partesAula: [],\r\n        fecha: new Date().toISOString().split('T')[0],\r\n        tramoActual: this.obtenerTramoActual(),\r\n        profesorGuardia: 'antonio.oliver@instituto.es',\r\n        modalTareas: null,\r\n        mensaje: '',\r\n        mensajeTipo: '',\r\n        cargando: false,\r\n        guardando: false\r\n      }\r\n    },\r\n    mounted() {\r\n      this.cargarPartes()\r\n    },\r\n    methods: {\r\n      obtenerTramoActual() {\r\n        const hora = new Date().getHours()\r\n        if (hora >= 8 && hora < 9) return '1'\r\n        if (hora >= 9 && hora < 10) return '2'\r\n        if (hora >= 10 && hora < 11) return '3'\r\n        if (hora >= 11 && hora < 12) return '4'\r\n        if (hora >= 12 && hora < 13) return '5'\r\n        if (hora >= 13 && hora < 14) return '6'\r\n        return '3' // Por defecto 3ª hora\r\n      },\r\n      \r\n      async cargarPartes() {\r\n        this.cargando = true\r\n        this.mensaje = ''\r\n        \r\n        try {\r\n          const response = await axios.get(`${API_URL}/partes/aula-convivencia`, {\r\n            params: { fecha: this.fecha }\r\n          })\r\n          \r\n          this.partesAula = response.data.map(parte => ({\r\n            ...parte,\r\n            trabaja: null,\r\n            comportamiento: ''\r\n          }))\r\n          \r\n          if (this.partesAula.length > 0) {\r\n            this.mensaje = `✅ Se encontraron ${this.partesAula.length} alumno(s) en el aula de convivencia`\r\n            this.mensajeTipo = 'success'\r\n          }\r\n        } catch (error) {\r\n          console.error('Error al cargar partes:', error)\r\n          this.mensaje = '❌ Error al cargar los partes del aula de convivencia'\r\n          this.mensajeTipo = 'error'\r\n        } finally {\r\n          this.cargando = false\r\n        }\r\n      },\r\n      \r\n      verTareas(parte) {\r\n        this.modalTareas = parte\r\n      },\r\n      \r\n      cerrarModal() {\r\n        this.modalTareas = null\r\n      },\r\n      \r\n      abrirDocumento(url) {\r\n        window.open(url, '_blank')\r\n      },\r\n      \r\n      async guardarSesiones() {\r\n        // Validar que al menos un alumno tenga evaluación\r\n        const partesConEvaluacion = this.partesAula.filter(\r\n          parte => parte.comportamiento || parte.trabaja !== null\r\n        )\r\n        \r\n        if (partesConEvaluacion.length === 0) {\r\n          this.mensaje = '⚠️ Por favor, evalúe al menos a un alumno antes de guardar'\r\n          this.mensajeTipo = 'error'\r\n          return\r\n        }\r\n        \r\n        if (!this.profesorGuardia) {\r\n          this.mensaje = '⚠️ Por favor, ingrese el email del profesor de guardia'\r\n          this.mensajeTipo = 'error'\r\n          return\r\n        }\r\n        \r\n        this.guardando = true\r\n        let guardados = 0\r\n        let errores = 0\r\n        \r\n        try {\r\n          for (const parte of partesConEvaluacion) {\r\n            try {\r\n              await axios.post(`${API_URL}/sesiones`, {\r\n                parteId: parte.id,\r\n                profesorGuardiaEmail: this.profesorGuardia,\r\n                fecha: this.fecha,\r\n                tramoHorario: this.tramoActual,\r\n                comportamiento: parte.comportamiento || null,\r\n                trabaja: parte.trabaja,\r\n                observaciones: ''\r\n              })\r\n              guardados++\r\n            } catch (error) {\r\n              console.error('Error al guardar sesión:', error)\r\n              errores++\r\n            }\r\n          }\r\n          \r\n          if (errores === 0) {\r\n            this.mensaje = `✅ Se guardaron ${guardados} evaluación(es) exitosamente`\r\n            this.mensajeTipo = 'success'\r\n            \r\n            setTimeout(() => {\r\n              this.mensaje = ''\r\n              this.cargarPartes()\r\n            }, 3000)\r\n          } else {\r\n            this.mensaje = `⚠️ Se guardaron ${guardados} evaluación(es), pero ${errores} tuvieron errores`\r\n            this.mensajeTipo = 'error'\r\n          }\r\n        } catch (error) {\r\n          console.error('Error general:', error)\r\n          this.mensaje = '❌ Error al guardar las evaluaciones'\r\n          this.mensajeTipo = 'error'\r\n        } finally {\r\n          this.guardando = false\r\n        }\r\n      },\r\n      \r\n      formatearFecha(fecha) {\r\n        if (!fecha) return ''\r\n        return new Date(fecha + 'T00:00:00').toLocaleDateString('es-ES', {\r\n          weekday: 'long',\r\n          day: '2-digit',\r\n          month: '2-digit',\r\n          year: 'numeric'\r\n        })\r\n      }\r\n    }\r\n  }\r\n  </script>\r\n  \r\n  <style scoped>\r\n  .header-guardia {\r\n    display: flex;\r\n    justify-content: space-between;\r\n    align-items: center;\r\n    margin-bottom: 2rem;\r\n    padding-bottom: 1.5rem;\r\n    border-bottom: 3px solid #667eea;\r\n  }\r\n  \r\n  .info-guardia {\r\n    color: #666;\r\n    margin-top: 0.75rem;\r\n    font-size: 1.05rem;\r\n  }\r\n  \r\n  .info-guardia strong {\r\n    color: #333;\r\n  }\r\n  \r\n  .filtros {\r\n    display: grid;\r\n    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));\r\n    gap: 1.5rem;\r\n    margin-bottom: 2rem;\r\n    background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);\r\n    padding: 2rem;\r\n    border-radius: 12px;\r\n    border: 2px solid #e0e0e0;\r\n  }\r\n  \r\n  .filtros .form-group {\r\n    margin-bottom: 0;\r\n  }\r\n  \r\n  .loading {\r\n    text-align: center;\r\n    padding: 3rem;\r\n    color: #667eea;\r\n    font-size: 1.1rem;\r\n  }\r\n  \r\n  .sin-alumnos {\r\n    padding: 3rem;\r\n  }\r\n  \r\n  .empty-state {\r\n    text-align: center;\r\n    padding: 3rem;\r\n    background: #f8f9fa;\r\n    border-radius: 12px;\r\n    border: 2px dashed #dee2e6;\r\n  }\r\n  \r\n  .empty-icon {\r\n    font-size: 4rem;\r\n    display: block;\r\n    margin-bottom: 1rem;\r\n  }\r\n  \r\n  .empty-state h3 {\r\n    color: #495057;\r\n    margin-bottom: 0.5rem;\r\n  }\r\n  \r\n  .empty-state p {\r\n    color: #6c757d;\r\n  }\r\n  \r\n  .tabla-container {\r\n    overflow-x: auto;\r\n  }\r\n  \r\n  table {\r\n    width: 100%;\r\n    border-collapse: collapse;\r\n    margin-top: 1rem;\r\n    background: white;\r\n    box-shadow: 0 2px 8px rgba(0,0,0,0.1);\r\n    border-radius: 8px;\r\n    overflow: hidden;\r\n  }\r\n  \r\n  table thead {\r\n    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\r\n    color: white;\r\n  }\r\n  \r\n  table th {\r\n    padding: 1.25rem;\r\n    text-align: left;\r\n    font-weight: 600;\r\n    font-size: 0.95rem;\r\n    text-transform: uppercase;\r\n    letter-spacing: 0.5px;\r\n  }\r\n  \r\n  table td {\r\n    padding: 1.25rem;\r\n    border-bottom: 1px solid #e0e0e0;\r\n  }\r\n  \r\n  table tbody tr:hover {\r\n    background: #f8f9fa;\r\n  }\r\n  \r\n  table tbody tr:last-child td {\r\n    border-bottom: none;\r\n  }\r\n  \r\n  .numero {\r\n    text-align: center;\r\n    font-weight: 600;\r\n    color: #667eea;\r\n    font-size: 1.1rem;\r\n  }\r\n  \r\n  .alumno-nombre {\r\n    color: #333;\r\n  }\r\n  \r\n  .centro {\r\n    text-align: center;\r\n  }\r\n  \r\n  .no-doc {\r\n    color: #ccc;\r\n    font-size: 1.2rem;\r\n  }\r\n  \r\n  .btn-icon {\r\n    background: none;\r\n    border: none;\r\n    font-size: 1.8rem;\r\n    cursor: pointer;\r\n    transition: transform 0.2s;\r\n  }\r\n  \r\n  .btn-icon:hover {\r\n    transform: scale(1.2);\r\n  }\r\n  \r\n  .btn-small {\r\n    padding: 0.5rem 1rem;\r\n    border: none;\r\n    border-radius: 6px;\r\n    cursor: pointer;\r\n    font-size: 0.9rem;\r\n    transition: all 0.3s;\r\n  }\r\n  \r\n  .btn-info {\r\n    background: #17a2b8;\r\n    color: white;\r\n  }\r\n  \r\n  .btn-info:hover {\r\n    background: #138496;\r\n    transform: translateY(-2px);\r\n  }\r\n  \r\n  .select-small {\r\n    padding: 0.6rem;\r\n    border: 2px solid #e0e0e0;\r\n    border-radius: 6px;\r\n    width: 100%;\r\n    font-size: 0.95rem;\r\n    transition: border-color 0.3s;\r\n    cursor: pointer;\r\n  }\r\n  \r\n  .select-small:focus {\r\n    outline: none;\r\n    border-color: #667eea;\r\n  }\r\n  \