{"ast":null,"code":"import axios from 'axios';\nconst API_URL = 'http://localhost:8080/api';\nexport default {\n  name: 'Historial',\n  data() {\n    return {\n      partes: [],\n      filtroFecha: '',\n      filtroProfesor: '',\n      parteSeleccionado: null\n    };\n  },\n  mounted() {\n    this.cargarPartes();\n  },\n  methods: {\n    async cargarPartes() {\n      try {\n        let url = `${API_URL}/partes`;\n        if (this.filtroFecha) {\n          url = `${API_URL}/partes/fecha/${this.filtroFecha}`;\n        } else if (this.filtroProfesor) {\n          url = `${API_URL}/partes/profesor/${this.filtroProfesor}`;\n        }\n        const response = await axios.get(url);\n        this.partes = response.data;\n      } catch (error) {\n        console.error('Error al cargar partes:', error);\n      }\n    },\n    limpiarFiltros() {\n      this.filtroFecha = '';\n      this.filtroProfesor = '';\n      this.cargarPartes();\n    },\n    verDetalle(parte) {\n      this.parteSeleccionado = parte;\n    },\n    formatearFecha(fecha) {\n      return new Date(fecha).toLocaleDateString('es-ES');\n    }\n  }\n};","map":{"version":3,"names":["axios","API_URL","name","data","partes","filtroFecha","filtroProfesor","parteSeleccionado","mounted","cargarPartes","methods","url","response","get","error","console","limpiarFiltros","verDetalle","parte","formatearFecha","fecha","Date","toLocaleDateString"],"sources":["C:\\Users\\Adrian\\Desktop\\partes-convivencia-completo\\frontend\\src\\components\\Historial.vue"],"sourcesContent":["<template>\r\n    <div class=\"card\">\r\n      <h2>📋 Historial de Partes</h2>\r\n  \r\n      <div class=\"filtros\">\r\n        <div class=\"form-group\">\r\n          <label>Filtrar por fecha</label>\r\n          <input type=\"date\" v-model=\"filtroFecha\" @change=\"cargarPartes\" />\r\n        </div>\r\n        <div class=\"form-group\">\r\n          <label>Filtrar por profesor (email)</label>\r\n          <input type=\"email\" v-model=\"filtroProfesor\" @input=\"cargarPartes\" placeholder=\"profesor@instituto.es\" />\r\n        </div>\r\n        <button @click=\"limpiarFiltros\" class=\"btn btn-secondary\">\r\n          🔄 Limpiar filtros\r\n        </button>\r\n      </div>\r\n  \r\n      <div v-if=\"partes.length === 0\" class=\"sin-datos\">\r\n        <p>📭 No hay partes registrados</p>\r\n      </div>\r\n  \r\n      <table v-else>\r\n        <thead>\r\n          <tr>\r\n            <th>ID</th>\r\n            <th>Fecha</th>\r\n            <th>Profesor</th>\r\n            <th>Alumno</th>\r\n            <th>Curso</th>\r\n            <th>Medida</th>\r\n            <th>Estado</th>\r\n            <th>Acciones</th>\r\n          </tr>\r\n        </thead>\r\n        <tbody>\r\n          <tr v-for=\"parte in partes\" :key=\"parte.id\">\r\n            <td>{{ parte.id }}</td>\r\n            <td>{{ formatearFecha(parte.fecha) }}</td>\r\n            <td>{{ parte.profesor.nombre }}</td>\r\n            <td>{{ parte.alumno.nombre }} {{ parte.alumno.apellidos }}</td>\r\n            <td>{{ parte.curso }}</td>\r\n            <td>\r\n              <span :class=\"['badge', parte.medidaTomada === 'AULA_CONVIVENCIA' ? 'badge-warning' : 'badge-info']\">\r\n                {{ parte.medidaTomada === 'AULA_CONVIVENCIA' ? 'Aula' : 'Clase' }}\r\n              </span>\r\n            </td>\r\n            <td>\r\n              <span :class=\"['badge', parte.estado === 'EVALUADO' ? 'badge-success' : 'badge-pending']\">\r\n                {{ parte.estado }}\r\n              </span>\r\n            </td>\r\n            <td>\r\n              <button @click=\"verDetalle(parte)\" class=\"btn-small btn-primary\">\r\n                👁️ Ver\r\n              </button>\r\n            </td>\r\n          </tr>\r\n        </tbody>\r\n      </table>\r\n  \r\n      <!-- Modal detalle -->\r\n      <div v-if=\"parteSeleccionado\" class=\"modal\" @click=\"parteSeleccionado = null\">\r\n        <div class=\"modal-content\" @click.stop>\r\n          <h3>📄 Detalle del Parte #{{ parteSeleccionado.id }}</h3>\r\n          \r\n          <div class=\"detalle-grid\">\r\n            <div class=\"detalle-item\">\r\n              <strong>Fecha:</strong> {{ formatearFecha(parteSeleccionado.fecha) }}\r\n            </div>\r\n            <div class=\"detalle-item\">\r\n              <strong>Profesor:</strong> {{ parteSeleccionado.profesor.nombre }}\r\n            </div>\r\n            <div class=\"detalle-item\">\r\n              <strong>Alumno:</strong> {{ parteSeleccionado.alumno.nombre }} {{ parteSeleccionado.alumno.apellidos }}\r\n            </div>\r\n            <div class=\"detalle-item\">\r\n              <strong>Curso:</strong> {{ parteSeleccionado.curso }}\r\n            </div>\r\n            <div class=\"detalle-item\">\r\n              <strong>Conducta:</strong> {{ parteSeleccionado.conducta.codigo }} - {{ parteSeleccionado.conducta.descripcion }}\r\n            </div>\r\n            <div class=\"detalle-item full-width\">\r\n              <strong>Descripción:</strong>\r\n              <p>{{ parteSeleccionado.descripcion }}</p>\r\n            </div>\r\n            <div class=\"detalle-item\">\r\n              <strong>Medida:</strong> {{ parteSeleccionado.medidaTomada === 'AULA_CONVIVENCIA' ? 'Aula de Convivencia' : 'Se queda en clase' }}\r\n            </div>\r\n            <div class=\"detalle-item\">\r\n              <strong>Estado:</strong> {{ parteSeleccionado.estado }}\r\n            </div>\r\n            <div v-if=\"parteSeleccionado.tareas\" class=\"detalle-item full-width\">\r\n              <strong>Tareas:</strong>\r\n              <p>{{ parteSeleccionado.tareas }}</p>\r\n            </div>\r\n            <div v-if=\"parteSeleccionado.archivoUrl\" class=\"detalle-item full-width\">\r\n              <strong>Documento:</strong>\r\n              <a :href=\"parteSeleccionado.archivoUrl\" target=\"_blank\">📎 Ver documento</a>\r\n            </div>\r\n          </div>\r\n  \r\n          <button @click=\"parteSeleccionado = null\" class=\"btn btn-secondary\">\r\n            Cerrar\r\n          </button>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </template>\r\n  \r\n  <script>\r\n  import axios from 'axios'\r\n  \r\n  const API_URL = 'http://localhost:8080/api'\r\n  \r\n  export default {\r\n    name: 'Historial',\r\n    data() {\r\n      return {\r\n        partes: [],\r\n        filtroFecha: '',\r\n        filtroProfesor: '',\r\n        parteSeleccionado: null\r\n      }\r\n    },\r\n    mounted() {\r\n      this.cargarPartes()\r\n    },\r\n    methods: {\r\n      async cargarPartes() {\r\n        try {\r\n          let url = `${API_URL}/partes`\r\n          \r\n          if (this.filtroFecha) {\r\n            url = `${API_URL}/partes/fecha/${this.filtroFecha}`\r\n          } else if (this.filtroProfesor) {\r\n            url = `${API_URL}/partes/profesor/${this.filtroProfesor}`\r\n          }\r\n          \r\n          const response = await axios.get(url)\r\n          this.partes = response.data\r\n        } catch (error) {\r\n          console.error('Error al cargar partes:', error)\r\n        }\r\n      },\r\n      limpiarFiltros() {\r\n        this.filtroFecha = ''\r\n        this.filtroProfesor = ''\r\n        this.cargarPartes()\r\n      },\r\n      verDetalle(parte) {\r\n        this.parteSeleccionado = parte\r\n      },\r\n      formatearFecha(fecha) {\r\n        return new Date(fecha).toLocaleDateString('es-ES')\r\n      }\r\n    }\r\n  }\r\n  </script>\r\n  \r\n  <style scoped>\r\n  .filtros {\r\n    display: flex;\r\n    gap: 1rem;\r\n    align-items: flex-end;\r\n    margin-bottom: 2rem;\r\n    background: #f8f9fa;\r\n    padding: 1.5rem;\r\n    border-radius: 8px;\r\n  }\r\n  \r\n  .filtros .form-group {\r\n    flex: 1;\r\n    margin-bottom: 0;\r\n  }\r\n  \r\n  .sin-datos {\r\n    text-align: center;\r\n    padding: 3rem;\r\n    color: #666;\r\n    font-size: 1.1rem;\r\n  }\r\n  \r\n  .badge {\r\n    padding: 0.4rem 0.8rem;\r\n    border-radius: 4px;\r\n    font-size: 0.85rem;\r\n    font-weight: 600;\r\n  }\r\n  \r\n  .badge-warning {\r\n    background: #fff3cd;\r\n    color: #856404;\r\n  }\r\n  \r\n  .badge-info {\r\n    background: #d1ecf1;\r\n    color: #0c5460;\r\n  }\r\n  \r\n  .badge-success {\r\n    background: #d4edda;\r\n    color: #155724;\r\n  }\r\n  \r\n  .badge-pending {\r\n    background: #f8d7da;\r\n    color: #721c24;\r\n  }\r\n  \r\n  .btn-small {\r\n    padding: 0.4rem 0.8rem;\r\n    font-size: 0.85rem;\r\n  }\r\n  \r\n  .modal {\r\n    position: fixed;\r\n    top: 0;\r\n    left: 0;\r\n    right: 0;\r\n    bottom: 0;\r\n    background: rgba(0,0,0,0.5);\r\n    display: flex;\r\n    align-items: center;\r\n    justify-content: center;\r\n    z-index: 1000;\r\n  }\r\n  \r\n  .modal-content {\r\n    background: white;\r\n    padding: 2rem;\r\n    border-radius: 12px;\r\n    max-width: 800px;\r\n    width: 90%;\r\n    max-height: 80vh;\r\n    overflow-y: auto;\r\n  }\r\n  \r\n  .detalle-grid {\r\n    display: grid;\r\n    grid-template-columns: repeat(2, 1fr);\r\n    gap: 1.5rem;\r\n    margin: 2rem 0;\r\n  }\r\n  \r\n  .detalle-item {\r\n    padding: 1rem;\r\n    background: #f8f9fa;\r\n    border-radius: 8px;\r\n  }\r\n  \r\n  .detalle-item.full-width {\r\n    grid-column: 1 / -1;\r\n  }\r\n  \r\n  .detalle-item strong {\r\n    display: block;\r\n    margin-bottom: 0.5rem;\r\n    color: #667eea;\r\n  }\r\n  \r\n  .detalle-item p {\r\n    margin: 0;\r\n    color: #333;\r\n  }\r\n  \r\n  .detalle-item a {\r\n    color: #667eea;\r\n    text-decoration: none;\r\n  }\r\n  \r\n  .detalle-item a:hover {\r\n    text-decoration: underline;\r\n  }\r\n  </style>"],"mappings":"AA+GE,OAAOA,KAAI,MAAO,OAAM;AAExB,MAAMC,OAAM,GAAI,2BAA0B;AAE1C,eAAe;EACbC,IAAI,EAAE,WAAW;EACjBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,MAAM,EAAE,EAAE;MACVC,WAAW,EAAE,EAAE;MACfC,cAAc,EAAE,EAAE;MAClBC,iBAAiB,EAAE;IACrB;EACF,CAAC;EACDC,OAAOA,CAAA,EAAG;IACR,IAAI,CAACC,YAAY,CAAC;EACpB,CAAC;EACDC,OAAO,EAAE;IACP,MAAMD,YAAYA,CAAA,EAAG;MACnB,IAAI;QACF,IAAIE,GAAE,GAAI,GAAGV,OAAO,SAAQ;QAE5B,IAAI,IAAI,CAACI,WAAW,EAAE;UACpBM,GAAE,GAAI,GAAGV,OAAO,iBAAiB,IAAI,CAACI,WAAW,EAAC;QACpD,OAAO,IAAI,IAAI,CAACC,cAAc,EAAE;UAC9BK,GAAE,GAAI,GAAGV,OAAO,oBAAoB,IAAI,CAACK,cAAc,EAAC;QAC1D;QAEA,MAAMM,QAAO,GAAI,MAAMZ,KAAK,CAACa,GAAG,CAACF,GAAG;QACpC,IAAI,CAACP,MAAK,GAAIQ,QAAQ,CAACT,IAAG;MAC5B,EAAE,OAAOW,KAAK,EAAE;QACdC,OAAO,CAACD,KAAK,CAAC,yBAAyB,EAAEA,KAAK;MAChD;IACF,CAAC;IACDE,cAAcA,CAAA,EAAG;MACf,IAAI,CAACX,WAAU,GAAI,EAAC;MACpB,IAAI,CAACC,cAAa,GAAI,EAAC;MACvB,IAAI,CAACG,YAAY,CAAC;IACpB,CAAC;IACDQ,UAAUA,CAACC,KAAK,EAAE;MAChB,IAAI,CAACX,iBAAgB,GAAIW,KAAI;IAC/B,CAAC;IACDC,cAAcA,CAACC,KAAK,EAAE;MACpB,OAAO,IAAIC,IAAI,CAACD,KAAK,CAAC,CAACE,kBAAkB,CAAC,OAAO;IACnD;EACF;AACF","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}